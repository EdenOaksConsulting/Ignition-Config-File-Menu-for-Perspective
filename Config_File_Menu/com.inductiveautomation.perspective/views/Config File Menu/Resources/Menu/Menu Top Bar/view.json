{
  "custom": {},
  "params": {
    "menuDockId": "config-file-menu"
  },
  "props": {
    "defaultSize": {
      "height": 60,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "domId": "menuToggleButton",
          "name": "MenuToggleButton"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "props": {
          "path": "material/menu",
          "style": {
            "alignItems": "center",
            "classes": "cfm-menu__button cfm-menu__button--open-menu",
            "cursor": "pointer",
            "display": "flex",
            "height": "40px",
            "justifyContent": "center",
            "maxHeight": "40px",
            "minHeight": "40px",
            "padding": "0",
            "width": "40px"
          }
        },
        "type": "ia.display.icon",
        "propConfig": {
          "props.path": {
            "binding": {
              "config": {
                "struct": {
                  "deviceType": "{session.props.device.type}",
                  "dockContent": "{session.custom.configFileMenu.dockContentPush}",
                  "isPinned": "{session.custom.configFileMenu.dockPinned}",
                  "isOpen": "{session.custom.configFileMenu.dockOpen}",
                  "viewportWidth": "{page.props.dimensions.viewport.width}",
                  "primaryViewWidth": "{page.props.dimensions.primaryView.width}"
                },
                "waitOnAll": true
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.topbar_toggle_icon(self)\n",
                  "type": "script"
                }
              ],
              "type": "expr-struct"
            }
          },
          "props.style.classes": {
            "binding": {
              "config": {
                "struct": {
                  "deviceType": "{session.props.device.type}",
                  "dockContent": "{session.custom.configFileMenu.dockContentPush}",
                  "isPinned": "{session.custom.configFileMenu.dockPinned}",
                  "isOpen": "{session.custom.configFileMenu.dockOpen}",
                  "viewportWidth": "{page.props.dimensions.viewport.width}",
                  "primaryViewWidth": "{page.props.dimensions.primaryView.width}"
                },
                "waitOnAll": true
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.topbar_toggle_classes(self)\n",
                  "type": "script"
                }
              ],
              "type": "expr-struct"
            }
          }
        },
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\texchange.cfm.runtime.on_menu_toggle_click(self)\n"
              },
              "scope": "G",
              "type": "script"
            }
          }
        }
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "struct": {
                  "path": "{page.props.path}",
                  "viewportWidth": "{page.props.dimensions.viewport.width}",
                  "menuConfig": "{session.custom.configFileMenu.contentSource}",
                  "menuConfigType": "{session.custom.configFileMenu.contentSourceType}",
                  "menuDockId": "{session.custom.configFileMenu.contentDockId}",
                  "pathPrefix": "{session.custom.configFileMenu.contentBreadcrumbPrefix}",
                  "siteName": "{session.custom.configFileMenu.brandSiteName}",
                  "prefMenuDockId": "{session.custom.configFileMenu.contentDockId}",
                  "shellFallbackEnabled": "{session.custom.configFileMenu.routeFallbackEnabled}",
                  "requestedPath": "{view.params.requestedPath}",
                  "logicalPagePath": "{session.custom.configFileMenu.routeLogicalPath}",
                  "routeLogicalPath": "{session.custom.configFileMenu.routeLogicalPath}",
                  "routeFallbackEnabled": "{session.custom.configFileMenu.routeFallbackEnabled}"
                },
                "waitOnAll": true
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.build_instances(value, self.page)\n",
                  "type": "script"
                }
              ],
              "type": "expr-struct"
            }
          }
        },
        "props": {
          "alignItems": "center",
          "elementPosition": {
            "basis": "auto",
            "grow": 0,
            "shrink": 0
          },
          "path": "Config File Menu/Resources/Menu/Menu Breadcrumb",
          "style": {
            "classes": "cfm-menu__topbar-breadcrumbs",
            "gap": "10px",
            "overflow": "hidden",
            "height": "40px",
            "maxHeight": "40px",
            "minHeight": "40px"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false,
          "elementStyle": {
            "alignItems": "center",
            "alignSelf": "center",
            "display": "flex",
            "height": "40px",
            "maxHeight": "40px",
            "minHeight": "40px",
            "overflow": "visible"
          }
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "meta": {
          "name": "TopBarClock"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{page.props.dimensions.viewport.width}>450 && {session.custom.configFileMenu.showTopBarClock}"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "runScript(\"exchange.cfm.runtime.format_topbar_clock\", if({session.custom.configFileMenu.showTopBarClock}, max(1, {session.custom.configFileMenu.clockRefreshSeconds}) * 1000, 0))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "cfm-menu__topbar-clock"
          },
          "text": ""
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "TopBarSmallLogo"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "fit": {
            "height": 32,
            "mode": "contain",
            "width": 32
          },
          "style": {
            "classes": "cfm-menu__topbar-logo cfm-menu__logo",
            "cursor": "pointer"
          }
        },
        "type": "ia.display.image",
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "struct": {
                  "viewportWidth": "{page.props.dimensions.viewport.width}",
                  "showTopBarSmallLogo": "{session.custom.configFileMenu.showTopBarSmallLogo}"
                },
                "waitOnAll": true
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.topbar_small_logo_visible(value, self.session)\n",
                  "type": "script"
                }
              ],
              "type": "expr-struct"
            }
          },
          "props.source": {
            "binding": {
              "config": {
                "struct": {
                  "variant": "'small'",
                  "sessionSource": "{session.custom.configFileMenu.brandLogoSmall}",
                  "defaultSource": "'data:image/png;base64,'"
                },
                "waitOnAll": true
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.resolve_logo_source(value, self.session, self.view)\n",
                  "type": "script"
                }
              ],
              "type": "expr-struct"
            }
          }
        },
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\texchange.cfm.runtime.on_logo_click(self)\n"
              },
              "scope": "G",
              "type": "script"
            }
          }
        }
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "style": {
        "classes": "cfm-menu__topbar",
        "minHeight": "40px"
      }
    },
    "type": "ia.container.flex",
    "events": {
      "component": {
        "onStartup": {
          "config": {
            "script": "\texchange.cfm.runtime.init_topbar_state(self)\n"
          },
          "scope": "G",
          "type": "script"
        }
      }
    }
  },
  "propConfig": {
    "params.menuDockId": {
      "paramDirection": "input",
      "persistent": true
    }
  }
}
