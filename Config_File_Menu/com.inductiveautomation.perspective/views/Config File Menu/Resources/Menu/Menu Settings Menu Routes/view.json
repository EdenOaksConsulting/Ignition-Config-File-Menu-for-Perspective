{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 720,
      "width": 1100
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Instructions"
        },
        "position": {
          "basis": "100px",
          "shrink": 0
        },
        "props": {
          "source": "Paste **menu YAML or JSON**, then click **Generate output**.\n\n**Dynamic Default** \u2014 every route uses the **Dynamic viewPath** (default: View Dynamic Fallback). Copy the `pages` object into `page-config/config.json`.\n\n**Create Views** \u2014 each route gets a unique `viewPath` derived from its target URL, and a matching `views` manifest for copy/paste view creation. Preserve `sharedDocks` and fixed routes (`/cfm/settings`, `/cfm/diagnostics`).",
          "style": {
            "padding": "8px 16px"
          }
        },
        "type": "ia.display.markdown"
      },
      {
        "meta": {
          "name": "MenuTypeRow"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "wrap": "nowrap",
          "style": {
            "classes": "cfm-menu__settings-form-row",
            "boxSizing": "border-box",
            "gap": "12px",
            "padding": "4px 16px",
            "width": "100%"
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "MenuTypeLabel"
            },
            "position": {
              "basis": "140px",
              "shrink": 0
            },
            "props": {
              "text": "Input type",
              "style": {
                "classes": "cfm-menu__settings-form-label",
                "fontSize": "14px",
                "textAlign": "right",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "MenuTypeDropdown"
            },
            "position": {
              "shrink": 1,
              "grow": 1
            },
            "props": {
              "options": [
                {
                  "label": "YAML",
                  "value": "yaml"
                },
                {
                  "label": "JSON",
                  "value": "json"
                }
              ],
              "value": "yaml",
              "style": {
                "classes": "cfm-menu__settings-form-field",
                "width": "100%",
                "minWidth": "0",
                "boxSizing": "border-box"
              }
            },
            "type": "ia.input.dropdown"
          }
        ]
      },
      {
        "meta": {
          "name": "OutputModeRow"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "wrap": "nowrap",
          "style": {
            "classes": "cfm-menu__settings-form-row",
            "boxSizing": "border-box",
            "gap": "12px",
            "padding": "4px 16px",
            "width": "100%"
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "OutputModeLabel"
            },
            "position": {
              "basis": "140px",
              "shrink": 0
            },
            "props": {
              "text": "Output mode",
              "style": {
                "classes": "cfm-menu__settings-form-label",
                "fontSize": "14px",
                "textAlign": "right",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "OutputModeDropdown"
            },
            "position": {
              "shrink": 1,
              "grow": 1
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "path": "session.custom.configFileMenu.menuRoutesGenerator.outputMode"
                  },
                  "transforms": [
                    {
                      "code": "\treturn str(value if value not in (None, '') else 'dynamic')",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "options": [
                {
                  "label": "Dynamic Default",
                  "value": "dynamic"
                },
                {
                  "label": "Create Views",
                  "value": "createViews"
                }
              ],
              "value": "dynamic",
              "style": {
                "classes": "cfm-menu__settings-form-field",
                "width": "100%",
                "minWidth": "0",
                "boxSizing": "border-box"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'outputMode', str(self.props.value or ''))\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "type": "ia.input.dropdown"
          }
        ]
      },
      {
        "meta": {
          "name": "ShellViewRow"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "wrap": "nowrap",
          "style": {
            "classes": "cfm-menu__settings-form-row",
            "boxSizing": "border-box",
            "gap": "12px",
            "padding": "4px 16px",
            "width": "100%"
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "ShellViewLabel"
            },
            "position": {
              "basis": "140px",
              "shrink": 0
            },
            "props": {
              "text": "Dynamic viewPath",
              "style": {
                "classes": "cfm-menu__settings-form-label",
                "fontSize": "14px",
                "textAlign": "right",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "ShellViewInput"
            },
            "position": {
              "shrink": 1,
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "session.custom.configFileMenu.menuRoutesGenerator.shellViewPath"
                  },
                  "transforms": [
                    {
                      "code": "\treturn str(value if value not in (None, '') else 'Config File Menu/Resources/View Dynamic Fallback')",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "text": "Config File Menu/Resources/View Dynamic Fallback",
              "style": {
                "fontFamily": "monospace",
                "fontSize": "14px",
                "classes": "cfm-menu__settings-form-field",
                "width": "100%",
                "minWidth": "0",
                "boxSizing": "border-box"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'shellViewPath', str(self.props.text or '').strip())\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              },
              "dom": {
                "onBlur": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'shellViewPath', str(self.props.text or '').strip())\n"
                  },
                  "scope": "G",
                  "type": "script"
                },
                "onKeyUp": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'shellViewPath', str(self.props.text or '').strip())\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "type": "ia.input.text-field"
          }
        ],
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "coalesce({session.custom.configFileMenu.menuRoutesGenerator.outputMode}, 'dynamic')='dynamic'"
              },
              "type": "expr"
            }
          }
        }
      },
      {
        "meta": {
          "name": "RoutesActionRow"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "direction": "row",
          "wrap": "nowrap",
          "style": {
            "classes": "cfm-menu__settings-form-row",
            "boxSizing": "border-box",
            "gap": "12px",
            "padding": "8px 16px 4px",
            "width": "100%"
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "ActionRowSpacer"
            },
            "position": {
              "basis": "140px",
              "shrink": 0
            },
            "props": {
              "text": "",
              "style": {
                "classes": "cfm-menu__settings-form-label"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\texchange.cfm.runtime.generate_output(self, 'Config File Menu/Resources/View Dynamic Fallback')\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "GenerateOutputButton"
            },
            "position": {
              "basis": "160px",
              "shrink": 0
            },
            "props": {
              "text": "Generate output",
              "style": {
                "alignSelf": "flex-start",
                "classes": "cfm-menu__settings-form-action"
              }
            },
            "type": "ia.input.button"
          }
        ]
      },
      {
        "meta": {
          "name": "RoutesStatusLabel"
        },
        "position": {
          "basis": "28px",
          "shrink": 0
        },
        "props": {
          "text": "Ready.",
          "style": {
            "classes": "cfm-menu__settings-status"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "MenuInputLabel"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "text": "Menu input",
                  "style": {
                    "classes": "cfm-menu__settings-panel-label",
                    "fontSize": "14px",
                    "fontWeight": "600",
                    "textAlign": "left"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "MenuInput"
                },
                "position": {
                  "grow": 1,
                  "shrink": 1
                },
                "props": {
                  "text": "# SAMPLE ONLY - Copy/paste into Config File Menu/MenuContent.params.menuConfig.\n# Every target needs a matching route in page-config/config.json.\n# expanded: true|false on a top-level section (or nested tree item) controls whether\n# that branch starts open. Sections still auto-open when the current page is under them.\nmenu:\n  items:\n    - label: Dashboard\n      icon: material/home\n      target: /cfm/dashboard\n",
                  "style": {
                    "fontFamily": "monospace",
                    "fontSize": "14px",
                    "boxSizing": "border-box",
                    "height": "100%",
                    "minHeight": "0",
                    "width": "100%"
                  },
                  "wrap": "off"
                },
                "type": "ia.input.text-area"
              }
            ],
            "meta": {
              "name": "MenuInputColumn"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "calc(50% - 8px)"
            },
            "props": {
              "direction": "column",
              "style": {
                "boxSizing": "border-box",
                "height": "100%",
                "minHeight": "0",
                "overflow": "hidden",
                "width": "100%"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "RoutesOutputLabel"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "props": {
                      "text": "Routes output",
                      "style": {
                        "classes": "cfm-menu__settings-panel-label",
                        "fontSize": "14px",
                        "fontWeight": "600",
                        "textAlign": "left"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "RoutesOutput"
                    },
                    "position": {
                      "grow": 1,
                      "shrink": 1
                    },
                    "props": {
                      "text": "{\n  \"_comment\": \"Generated routes appear here.\",\n  \"pages\": {}\n}",
                      "style": {
                        "fontFamily": "monospace",
                        "fontSize": "14px",
                        "boxSizing": "border-box",
                        "height": "100%",
                        "minHeight": "0",
                        "width": "100%"
                      },
                      "wrap": "off"
                    },
                    "type": "ia.input.text-area"
                  }
                ],
                "meta": {
                  "name": "RoutesOutputColumn"
                },
                "position": {
                  "grow": 1,
                  "shrink": 1
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "boxSizing": "border-box",
                    "height": "100%",
                    "minHeight": "0",
                    "overflow": "hidden",
                    "width": "100%"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "ViewsOutputLabel"
                    },
                    "position": {
                      "shrink": 0
                    },
                    "props": {
                      "text": "Views manifest",
                      "style": {
                        "classes": "cfm-menu__settings-panel-label",
                        "fontSize": "14px",
                        "fontWeight": "600",
                        "textAlign": "left"
                      }
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "ViewsOutput"
                    },
                    "position": {
                      "grow": 1,
                      "shrink": 1
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.menuRoutesGenerator.viewsOutput"
                          },
                          "transforms": [
                            {
                              "code": "\treturn str(value if value not in (None, '') else '')",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      }
                    },
                    "props": {
                      "text": "",
                      "style": {
                        "fontFamily": "monospace",
                        "fontSize": "14px",
                        "padding": "8px",
                        "boxSizing": "border-box",
                        "height": "100%",
                        "maxHeight": "none",
                        "minHeight": "0",
                        "overflow": "auto",
                        "width": "100%"
                      },
                      "wrap": "off"
                    },
                    "events": {
                      "component": {
                        "onActionPerformed": {
                          "config": {
                            "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'viewsOutput', str(self.props.text or '').strip())\n"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      },
                      "dom": {
                        "onBlur": {
                          "config": {
                            "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'viewsOutput', str(self.props.text or '').strip())\n"
                          },
                          "scope": "G",
                          "type": "script"
                        },
                        "onKeyUp": {
                          "config": {
                            "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'menuRoutesGenerator', 'viewsOutput', str(self.props.text or '').strip())\n"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    },
                    "type": "ia.input.text-area"
                  }
                ],
                "meta": {
                  "name": "ViewsOutputColumn"
                },
                "position": {
                  "grow": 1,
                  "shrink": 1
                },
                "props": {
                  "direction": "column",
                  "style": {
                    "boxSizing": "border-box",
                    "height": "100%",
                    "minHeight": "0",
                    "overflow": "hidden",
                    "width": "100%"
                  }
                },
                "type": "ia.container.flex",
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "expression": "coalesce({session.custom.configFileMenu.menuRoutesGenerator.outputMode}, 'dynamic')='createViews'"
                      },
                      "type": "expr"
                    }
                  }
                }
              }
            ],
            "meta": {
              "name": "OutputColumn"
            },
            "position": {
              "basis": "calc(50% - 8px)",
              "grow": 1,
              "shrink": 1
            },
            "props": {
              "direction": "column",
              "style": {
                "boxSizing": "border-box",
                "gap": "16px",
                "height": "100%",
                "minHeight": "0",
                "overflow": "hidden",
                "width": "100%"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Panels"
        },
        "position": {
          "grow": 1,
          "shrink": 1
        },
        "props": {
          "style": {
            "boxSizing": "border-box",
            "gap": "16px",
            "minHeight": "0",
            "overflow": "hidden",
            "padding": "0 16px 16px",
            "width": "100%"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "component": {
        "onStartup": {
          "config": {
            "script": "\texchange.cfm.runtime.load_menu_routes_generator(self, \"# SAMPLE ONLY - Copy/paste into Config File Menu/MenuContent.params.menuConfig.\\n# Every target needs a matching route in page-config/config.json.\\n# expanded: true|false on a top-level section (or nested tree item) controls whether\\n# that branch starts open. Sections still auto-open when the current page is under them.\\nmenu:\\n  items:\\n    - label: Dashboard\\n      icon: material/home\\n      target: /cfm/dashboard\\n\", \"{\\n  \\\"_comment\\\": \\\"Generated routes appear here.\\\",\\n  \\\"pages\\\": {}\\n}\", 'Config File Menu/Resources/View Dynamic Fallback')\n"
          },
          "scope": "G",
          "type": "script"
        },
        "onShutdown": {
          "config": {
            "script": "\texchange.cfm.runtime.shutdown_menu_routes_generator(self, 'Config File Menu/Resources/View Dynamic Fallback')\n"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "boxSizing": "border-box",
        "height": "100%",
        "overflow": "hidden",
        "width": "100%"
      }
    },
    "type": "ia.container.flex"
  }
}
