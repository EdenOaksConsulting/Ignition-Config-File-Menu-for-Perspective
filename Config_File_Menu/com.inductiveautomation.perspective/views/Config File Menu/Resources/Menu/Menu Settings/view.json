                "padding": "0 16px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "TabBar"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "flex-end",
          "direction": "row",
          "style": {
            "classes": "cfm-menu__settings-tabbar"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "TabContent"
        },
        "position": {
          "grow": 1,
          "shrink": 1
        },
        "propConfig": {
          "props.path": {
            "binding": {
              "config": {
                "path": "view.custom.currentTabIndex"
              },
              "transforms": [
                {
                  "code": "\treturn exchange.cfm.runtime.settings_tab_view_path(value)\n",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "path": "Config File Menu/Resources/Menu/Menu Settings General",
          "style": {
            "classes": "cfm-menu__settings-content",
            "height": "100%",
            "width": "100%"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.view"
      }
    ],
    "events": {
      "component": {
        "onStartup": {
          "config": {
            "script": "\texchange.cfm.runtime.init_settings_shell_state(self)\n"
          },
          "scope": "G",
          "type": "script"
        }
      },
      "dom": {
        "onClick": {
          "config": {
            "script": "\texchange.cfm.runtime.close_on_outside_click(self)\n"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "cfm-menu__settings",
        "height": "100%"
      }
    },
    "type": "ia.container.flex"
  }
