                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "TagPathInput"
            },
            "position": {
              "shrink": 1,
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "session.custom.configFileMenu.settingsTagMenu.tagPath"
                  },
                  "transforms": [
                    {
                      "code": "\treturn str(value if value not in (None, '') else '[default]')",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "text": "[default]",
              "style": {
                "fontFamily": "monospace",
                "fontSize": "14px",
                "classes": "cfm-menu__settings-form-field",
                "width": "100%",
                "minWidth": "0",
                "boxSizing": "border-box"
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'settingsTagMenu', 'tagPath', str(self.props.text or '').strip())\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              },
              "dom": {
                "onBlur": {
                  "config": {
                    "script": "\texchange.cfm.runtime.set_session_block_field(self.session, 'settingsTagMenu', 'tagPath', str(self.props.text or '').strip())\n"
