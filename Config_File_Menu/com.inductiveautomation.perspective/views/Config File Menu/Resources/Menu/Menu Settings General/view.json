                  "config": {
                    "script": "\troute = str(self.props.text or '/cfm/target-no-route').strip()\n\tif not route.startswith('/'):\n\t\troute = '/' + route\n\texchange.cfm.runtime.set_state_field(self.session, 'routeFallbackPath', route)\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              },
              "dom": {
