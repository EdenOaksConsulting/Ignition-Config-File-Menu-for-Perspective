                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tval = self.props.value\n\tif val in (True, False):\n\t\texchange.cfm.runtime.set_state_field(self.session, 'routeFallbackEnabled', val)\n\telse:\n\t\texchange.cfm.runtime.set_state_field(self.session, 'routeFallbackEnabled', exchange.cfm.runtime.is_true(val))\n"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            }
