{
  "custom": {},
  "params": {},
  "propConfig": {},
  "props": {
    "defaultSize": {
      "height": 965,
      "width": 220
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "HeaderArea"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "direction": "row",
              "style": {
                "classes": "cfm-menu__header-area",
                "width": "100%"
              },
              "justify": "space-between"
            },
            "type": "ia.container.flex",
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "MenuLargeBreakpoint"
                    },
                    "props": {
                      "fit": {
                        "height": 56,
                        "mode": "contain",
                        "width": 144
                      },
                      "style": {
                        "classes": "cfm-menu__logo",
                        "height": "80px",
                        "alignSelf": "center"
                      }
                    },
                    "type": "ia.display.image",
                    "propConfig": {
                      "position.display": {
                        "binding": {
                          "config": {
                            "expression": "{session.custom.configFileMenu.showMenuLogo}"
                          },
                          "type": "expr"
                        }
                      },
                      "props.source": {
                        "binding": {
                          "config": {
                            "struct": {
                              "variant": "'large'",
                              "sessionSource": "{session.custom.configFileMenu.brandLogoLarge}",
                              "defaultSource": "'data:image/png;base64,'"
                            },
                            "waitOnAll": true
                          },
                          "transforms": [
                            {
                              "code": "\treturn exchange.cfm.runtime.resolve_logo_source(value, self.session, self.view)\n",
                              "type": "script"
                            }
                          ],
                          "type": "expr-struct"
                        }
                      }
                    }
                  }
                ],
                "meta": {
                  "name": "TopLogo"
                },
                "position": {
                  "shrink": 1,
                  "grow": 1
                },
                "props": {
                  "alignItems": "center",
                  "justify": "center",
                  "style": {
                    "classes": "cfm-menu__top-logo",
                    "height": "80px",
                    "minHeight": "80px",
                    "overflow": "hidden",
                    "minWidth": "0",
                    "width": "100%"
                  }
                },
                "type": "ia.container.flex",
                "propConfig": {
                  "props.style.cursor": {
                    "binding": {
                      "config": {
                        "expression": "'pointer'"
                      },
                      "type": "expr"
                    }
                  }
                },
                "events": {
                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "\texchange.cfm.runtime.on_logo_click(self)\n"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                }
              },
              {
                "meta": {
                  "name": "DockControls"
                },
                "position": {
                  "shrink": 0
                },
                "props": {
                  "alignItems": "flex-end",
                  "direction": "column",
                  "justify": "center",
                  "style": {
                    "classes": "cfm-menu__dock-controls",
                    "gap": "4px",
                    "paddingRight": "8px"
                  }
                },
                "type": "ia.container.flex",
                "children": [
                  {
                    "meta": {
                      "domId": "menuDockModeButton",
                      "name": "MenuDockModeButton",
                      "tooltip": {
                        "delay": 400,
                        "enabled": true,
                        "text": "Push mode \u2014 switch to cover"
                      }
                    },
                    "position": {
                      "basis": "38px",
                      "grow": 0,
                      "shrink": 0
                    },
                    "props": {
                      "path": "material/view_column",
                      "style": {
                        "classes": "cfm-menu__button cfm-menu__button--dock-mode cfm-menu__button--dock-compact",
                        "cursor": "pointer",
                        "height": "20px",
                        "width": "20px"
                      }
                    },
                    "type": "ia.display.icon",
                    "propConfig": {
                      "meta.tooltip.text": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockContentPush"
                          },
                          "transforms": [
                            {
                              "code": "\tpush = value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on')\n\tif push:\n\t\treturn 'Push mode \u2014 switch to cover'\n\treturn 'Cover mode \u2014 switch to push'",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      },
                      "props.path": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockContentPush"
                          },
                          "transforms": [
                            {
                              "code": "\tpush = value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on')\n\treturn 'material/view_column' if push else 'material/layers'",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      },
                      "props.style.classes": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockContentPush"
                          },
                          "transforms": [
                            {
                              "code": "\tbase = 'cfm-menu__button cfm-menu__button--dock-mode cfm-menu__button--dock-compact'\n\tpush = value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on')\n\tif not push:\n\t\treturn base + ' cfm-menu__button--active'\n\treturn base",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      }
                    },
                    "events": {
                      "dom": {
                        "onClick": {
                          "config": {
                            "script": "\texchange.cfm.runtime.on_dock_mode_toggle(self)\n"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    }
                  },
                  {
                    "meta": {
                      "domId": "menuDockPinButton",
                      "name": "MenuDockPinButton",
                      "tooltip": {
                        "delay": 400,
                        "enabled": true,
                        "text": "Pin menu open"
                      }
                    },
                    "position": {
                      "basis": "38px",
                      "grow": 0,
                      "shrink": 0
                    },
                    "props": {
                      "path": "material/lock_open",
                      "style": {
                        "classes": "cfm-menu__button cfm-menu__button--dock-pin cfm-menu__button--dock-compact",
                        "cursor": "pointer",
                        "height": "20px",
                        "width": "20px"
                      }
                    },
                    "type": "ia.display.icon",
                    "propConfig": {
                      "meta.tooltip.text": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockPinned"
                          },
                          "transforms": [
                            {
                              "code": "\tif value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on'):\n\t\treturn 'Pinned open \u2014 click to unpin'\n\treturn 'Pin menu open'",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      },
                      "props.path": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockPinned"
                          },
                          "transforms": [
                            {
                              "code": "\tif value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on'):\n\t\treturn 'material/lock'\n\treturn 'material/lock_open'",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      },
                      "props.style.classes": {
                        "binding": {
                          "config": {
                            "path": "session.custom.configFileMenu.dockPinned"
                          },
                          "transforms": [
                            {
                              "code": "\tbase = 'cfm-menu__button cfm-menu__button--dock-pin cfm-menu__button--dock-compact'\n\tif value is None or value is True or str(value).lower() in ('true', '1', 'yes', 'on'):\n\t\treturn base + ' cfm-menu__button--active'\n\treturn base",
                              "type": "script"
                            }
                          ],
                          "type": "property"
                        }
                      }
                    },
                    "events": {
                      "dom": {
                        "onClick": {
                          "config": {
                            "script": "\texchange.cfm.runtime.on_dock_pin_toggle(self)\n"
                          },
                          "scope": "G",
                          "type": "script"
                        }
                      }
                    }
                  }
                ],
                "propConfig": {}
              }
            ],
            "propConfig": {}
          },
          {
            "meta": {
              "name": "MenuItems"
            },
            "position": {
              "basis": "auto",
              "grow": 0,
              "shrink": 0
            },
            "propConfig": {
              "props.instances": {
                "binding": {
                  "config": {
                    "struct": {
                      "paramMenuConfig": "{session.custom.configFileMenu.contentSource}",
                      "paramMenuConfigType": "{session.custom.configFileMenu.contentSourceType}"
                    },
                    "waitOnAll": true
                  },
                  "transforms": [
                    {
                      "code": "\treturn exchange.cfm.runtime.menu_items_transform(value, self.session, self.view)\n",
                      "type": "script"
                    }
                  ],
                  "type": "expr-struct"
                }
              }
            },
            "props": {
              "direction": "column",
              "elementPosition": {
                "basis": "auto",
                "grow": 0,
                "shrink": 0
              },
              "elementStyle": {
                "overflow": "visible"
              },
              "path": "Config File Menu/Resources/Menu/Menu Parent",
              "style": {
                "classes": "cfm-menu__repeater",
                "gap": "5px",
                "overflow": "visible"
              },
              "useDefaultViewHeight": false,
              "useDefaultViewWidth": false
            },
            "type": "ia.display.flex-repeater"
          },
          {
            "meta": {
              "name": "MenuFooter"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "marginTop": "auto"
              }
            },
            "type": "ia.container.flex",
            "children": [
              {
                "meta": {
                  "name": "MenuFooterDiagnostics"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "path": "session.custom.configFileMenu.showFooterDiagnostics"
                      },
                      "transforms": [
                        {
                          "code": "\treturn exchange.cfm.runtime.footer_visible(value, self.session, 'showDiagnostics', True)\n",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "path": "Config File Menu/Resources/Menu/Menu Child",
                  "params": {
                    "icon": "material/medical_services",
                    "isLink": true,
                    "label": "Diagnostics",
                    "menuDockId": "config-file-menu",
                    "showArrow": false,
                    "target": "/cfm/diagnostics"
                  },
                  "style": {
                    "classes": "cfm-menu__direct-link-embed"
                  }
                },
                "type": "ia.display.view"
              },
              {
                "meta": {
                  "name": "MenuFooterSettings"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "path": "session.custom.configFileMenu.showFooterSettings"
                      },
                      "transforms": [
                        {
                          "code": "\treturn exchange.cfm.runtime.footer_visible(value, self.session, 'showSettings', True)\n",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "path": "Config File Menu/Resources/Menu/Menu Child",
                  "params": {
                    "icon": "material/settings",
                    "isLink": true,
                    "label": "Settings",
                    "menuDockId": "config-file-menu",
                    "showArrow": false,
                    "target": "/cfm/settings"
                  },
                  "style": {
                    "classes": "cfm-menu__direct-link-embed"
                  }
                },
                "type": "ia.display.view"
              },
              {
                "meta": {
                  "name": "MenuSectionUser"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "path": "session.custom.configFileMenu.showFooterUser"
                      },
                      "transforms": [
                        {
                          "code": "\treturn exchange.cfm.runtime.footer_visible(value, self.session, 'showUser', True)\n",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "loading": {
                    "order": "with-parent"
                  },
                  "path": "Config File Menu/Resources/Menu/Menu Section User"
                },
                "type": "ia.display.view"
              }
            ],
            "propConfig": {}
          }
        ],
        "meta": {
          "name": "MenuContent"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "cfm-menu__content cfm-menu__panel",
            "backgroundColor": "var(--neutral-10)",
            "minHeight": "100%"
          }
        },
        "type": "ia.container.flex",
        "propConfig": {}
      }
    ],
    "meta": {
      "domId": "menu",
      "name": "root"
    },
    "propConfig": {
      "props.style": {
        "binding": {
          "config": {
            "struct": {
              "deviceType": "{session.props.device.type}",
              "isOpen": "{session.custom.configFileMenu.dockOpen}",
              "menuFont": "{session.custom.configFileMenu.layoutFont}",
              "menuFontSize": "{session.custom.configFileMenu.layoutFontSize}",
              "menuWidthOpen": "{session.custom.configFileMenu.layoutWidthOpen}"
            },
            "waitOnAll": true
          },
          "transforms": [
            {
              "code": "\treturn exchange.cfm.runtime.menu_panel_style(self.session)\n",
              "type": "script"
            }
          ],
          "type": "expr-struct"
        }
      }
    },
    "events": {
      "component": {
        "onStartup": {
          "config": {
            "script": "\texchange.cfm.runtime.init_menu_content_state(self)\n"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "cfm-menu__panel",
        "height": "100%",
        "backgroundColor": "var(--neutral-10)",
        "minHeight": "100%"
      }
    },
    "type": "ia.container.flex"
  }
}
